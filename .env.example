# .env.example — шаблон файла окружения
#
# 1. Скопируй этот файл и переименуй копию в ".env"
# 2. Вставь свои реальные значения вместо примеров ниже
# 3. Файл ".env" НИКОГДА не должен попадать в Git — он уже добавлен в .gitignore

# Токен бота от @BotFather
BOT_TOKEN=ВАШ_ТОКЕН_ОТ_BOTFATHER

# ID администраторов через запятую (без пробелов)
ADMIN_IDS=655446281
